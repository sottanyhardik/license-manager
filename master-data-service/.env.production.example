# Master-Data Service — PRODUCTION environment template (ADR-001).
#
# Copy to the host, NOT into git, at /etc/mds/mds.env:
#   sudo install -o root -g mds -m 640 this-file /etc/mds/mds.env
# The systemd unit loads it via EnvironmentFile=/etc/mds/mds.env.
# Every value below MUST be replaced. Nothing here is a usable secret.

# --- Core -------------------------------------------------------------------
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(64))'
SECRET_KEY=REPLACE_WITH_A_UNIQUE_50+_CHAR_RANDOM_SECRET

# MUST be false in production. Turns on SSL redirect, secure cookies, HSTS,
# nosniff (see mds/settings.py prod-hardening block).
DEBUG=False

# REAL hosts only — NEVER "*". Django rejects requests to other Host headers.
# Include the internal domain nginx serves and the loopback for local probes.
ALLOWED_HOSTS=masters.internal.example.com,127.0.0.1

TIME_ZONE=Asia/Kolkata

# --- Optional prod-hardening toggles (all default to safe-for-prod when
#     DEBUG=False; listed here so operators can see/override them) -----------
# SECURE_SSL_REDIRECT=true          # 301 http→https at Django (nginx also does it)
# SECURE_HSTS_SECONDS=31536000      # 1 year; only enable once TLS is stable
# SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# SECURE_HSTS_PRELOAD=false         # only set true if you will submit to the preload list
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
# USE_WHITENOISE=true               # serve admin static via whitenoise

# --- Database (its OWN Postgres DB + least-privilege role; consumers never
#     connect to this DB) ---------------------------------------------------
MDS_DB_NAME=master_data
MDS_DB_USER=master_data
MDS_DB_PASS=master_data
MDS_DB_HOST=127.0.0.1
MDS_DB_PORT=5432

# --- Service-to-service tokens ----------------------------------------------
# Format: "token:scope" comma-separated. scope = read | write (write implies read).
# ONE scoped token PER consumer server so a leak/rotation is isolated to one peer.
# Generate each: python -c 'import secrets; print(secrets.token_urlsafe(48))'
#
#   license-manager (143.110.252.201)  -> write   (canonical source)
#   labdhi          (139.59.92.226)     -> write
#   tractor         (165.232.185.220)   -> write
#   probe/monitoring                    -> read    (health dashboards only)
#
# Replace every REPLACE_* below with a distinct generated token value.
MDS_TOKENS=REPLACE_LICMGR_WRITE_TOKEN:write,REPLACE_LABDHI_WRITE_TOKEN:write,REPLACE_TRACTOR_WRITE_TOKEN:write,REPLACE_PROBE_READ_TOKEN:read

# --- gunicorn overrides (optional; defaults in deploy/gunicorn.conf.py) -----
# GUNICORN_WORKERS=5
# GUNICORN_BIND=127.0.0.1:8100
# GUNICORN_TIMEOUT=30
