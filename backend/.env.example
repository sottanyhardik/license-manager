DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database — choose ONE of the two styles below:
#
# Style A: Full DSN (recommended for Docker / Railway / Heroku)
DATABASE_URL=postgresql://lmanagement:lmanagement@localhost:5432/lmanagement
#
# Style B: Individual env vars (matches legacy lmanagement/settings.py naming)
# DB_NAME=lmanagement
# DB_USER=lmanagement
# DB_PASS=lmanagement
# DB_HOST=localhost
# DB_PORT=5432

REDIS_URL=redis://localhost:6379
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Production-only (set these for prod deployments)
# ALLOWED_HOSTS=license-manager.duckdns.org,labdhi.duckdns.org
# DEBUG=False
# SENTRY_DSN=https://...
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@example.com
# EMAIL_HOST_PASSWORD=CHANGE_ME
# CELERY_BROKER_URL=redis://localhost:6379/2
# CELERY_RESULT_BACKEND=redis://localhost:6379/3
