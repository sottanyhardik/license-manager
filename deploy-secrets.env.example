# Deploy secrets for scripts/deployment/auto-deploy.sh — COPY to `deploy-secrets.env` and fill in.
#
#   cp deploy-secrets.env.example deploy-secrets.env
#   # edit deploy-secrets.env with the real values
#   ./scripts/deployment/run-deploy.sh                 # deploys feature/Phase2 to all servers, MDS on
#
# `deploy-secrets.env` is git-ignored so real secrets never land in the repo.
# These are consumed by scripts/deployment/auto-deploy.sh (DEPLOY_PASSWORD gates the whole run;
# MDS_* drive the master-data sync — without them MDS is still enabled but the
# sync step is skipped with a warning, and the app keeps serving from the mirror).

# SSH + sudo password for the `django` user on every server (required).
export DEPLOY_PASSWORD='CHANGE_ME'

# Central Master-Data Service (required only for the master-data sync to run).
export MDS_BASE_URL='https://masters.<host>/api/v1/'
export MDS_TOKEN='<write-scoped token>'

# Optional: set MDS_ENABLED=false to deploy WITHOUT turning MDS on (defaults true).
# export MDS_ENABLED='true'
