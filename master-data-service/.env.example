# Master-Data Service — environment template. Copy to .env and fill in.
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=masters.internal,localhost

# Its own Postgres database (separate from any consuming project)
MDS_DB_NAME=master_data
MDS_DB_USER=master_data
MDS_DB_PASS=change-me
MDS_DB_HOST=localhost
MDS_DB_PORT=5432

# Service-to-service tokens: "token:scope" comma-separated. scope = read | write
# e.g. license-manager gets write, a reporting project gets read.
MDS_TOKENS=license-mgr-token:write,labdhi-token:write,tractor-token:write

TIME_ZONE=Asia/Kolkata
